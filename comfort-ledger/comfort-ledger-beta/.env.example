PORT=8787
NODE_ENV=development
COMFORT_SESSION_SECRET=change-me-to-a-long-random-string
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
COMFORT_SUBSCRIBE_URL=https://your-site.com/subscribe
COMFORT_ACCESS_MODE=beta
# Visitantes sin sesión beta (p. ej. enlace desde el landing): minutos de demo en este navegador. 0 = sin límite.
COMFORT_LANDING_DEMO_MINUTES=10
# Solo aplica si COMFORT_ACCESS_MODE=beta: exige login (true) o permite probar sin cuenta y aplica solo la demo de arriba (false).
COMFORT_REQUIRE_BETA_LOGIN=true
COMFORT_DATA_DIR=

# --- LemonSqueezy billing ---
# Crea una API key en https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=
# ID numérico de tu tienda (Store → Settings)
LEMONSQUEEZY_STORE_ID=
# IDs de las dos variantes del producto "Comfort Ledger" (mensual y anual)
LEMONSQUEEZY_VARIANT_MONTHLY=
LEMONSQUEEZY_VARIANT_ANNUAL=
# Secreto del webhook (lo defines tú al crearlo en LemonSqueezy → Settings → Webhooks)
LEMONSQUEEZY_WEBHOOK_SECRET=
# A dónde redirige LemonSqueezy tras un pago exitoso (opcional). Ej: https://comfortledger.app/app
COMFORT_CHECKOUT_REDIRECT_URL=
# Pon "true" cuando estés listo para mostrar botones de compra en el landing.
# Si está en "false" o LemonSqueezy no está configurado, el landing solo capta waitlist.
COMFORT_PUBLIC_PURCHASE=false
